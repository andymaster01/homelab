# -----------------------------------------------------------
# Terraform / Proxmox
# -----------------------------------------------------------
TF_VAR_proxmox_api_token="user@pam!token-id=your-secret-here"
TF_VAR_vm_ssh_public_key="ssh-ed25519 AAAA... user@host"

# -----------------------------------------------------------
# Docker / Jellyfin
# -----------------------------------------------------------
PUID=1000
PGID=1000
TZ=America/New_York
SMB_USER=your_smb_username
SMB_PASS=your_smb_password
SMB_SHARE=//192.168.1.x/share_name
