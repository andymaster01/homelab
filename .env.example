# -----------------------------------------------------------
# Terraform / Proxmox
# -----------------------------------------------------------
TF_VAR_proxmox_api_token="user@pam!token-id=your-secret-here"
TF_VAR_vm_ssh_public_key="ssh-ed25519 AAAA... user@host"

# -----------------------------------------------------------
# Docker / Jellyfin
# -----------------------------------------------------------
PUID=1000
PGID=1000
TZ=America/New_York

# -----------------------------------------------------------
# File Server (Samba + NFS)
# -----------------------------------------------------------
FILESERVER_SMB_USER=your_fileserver_smb_username
FILESERVER_SMB_PASS=your_fileserver_smb_password

# -----------------------------------------------------------
# Restic / Resticprofile
# -----------------------------------------------------------
RESTIC_PHOTOS_PASSPHRASE=your-strong-passphrase-for-photos
RESTIC_VIDEOS_PASSPHRASE=your-strong-passphrase-for-videos
HETZNER_SFTP_USER=u123456
HETZNER_SFTP_HOST=u123456.your-storagebox.de
HEALTHCHECKS_PHOTOS_HETZNER_URL=https://hc-ping.com/your-photos-hetzner-uuid
HEALTHCHECKS_PHOTOS_ONEDRIVE_URL=https://hc-ping.com/your-photos-onedrive-uuid
HEALTHCHECKS_VIDEOS_HETZNER_URL=https://hc-ping.com/your-videos-hetzner-uuid
HEALTHCHECKS_VIDEOS_ONEDRIVE_URL=https://hc-ping.com/your-videos-onedrive-uuid

# Base64-encoded SSH private key for Hetzner Storage Box
# Generate: cat ~/.ssh/restic_hetzner | base64 -w0
RESTIC_SSH_PRIVATE_KEY=

# SSH known_hosts entry for Hetzner (one line)
# Generate: ssh-keyscan u123456.your-storagebox.de
RESTIC_SSH_KNOWN_HOSTS=

# Base64-encoded rclone.conf with OneDrive OAuth token
# Used for restic rclone backend and plain file sync
# Generate: cat ~/.config/rclone/rclone.conf | base64 -w0
RESTIC_RCLONE_CONF=
