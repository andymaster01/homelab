# Copy to .env and fill in values

# Docker user/group IDs (typically 1000 on Linux)
PUID=1000
PGID=1000

# Timezone (e.g., America/New_York, Europe/London, Asia/Tokyo)
TZ=America/New_York

# SMB/CIFS credentials for accessing //192.168.1.111/homedata
SMB_USER=your_smb_username
SMB_PASS=your_smb_password
